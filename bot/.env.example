# Renombra este archivo a .env y rellena los valores reales.
# Discloud lee automáticamente el .env del ZIP al deployar — NO hace falta
# meter las variables a mano en su panel.

# ── Discord ────────────────────────────────────────────────
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=

# ── Configuración de puntos ────────────────────────────────
POINTS_PER_MESSAGE=1
# Puntos otorgados por cada "intervalo" completo en voz.
POINTS_PER_VOICE_MINUTE=1
# Cuántos minutos completos = 1 intervalo. Con 2 → 1 punto cada 2 min.
VOICE_MINUTES_PER_POINT=2
POINTS_PER_REACTION=10
MESSAGE_COOLDOWN_SECONDS=60
# IDs de canales separados por coma; ej: 1234567890,9876543210
EXCLUDED_CHANNEL_IDS=

# ── Canal de artes (#artes) — solo aquí se cuentan reacciones de corazón
# sobre mensajes publicados con el webhook de Melon Hub. Mismo valor que
# MELON_HUB_CHANNEL_ID en el .env del sitio.
MELON_HUB_CHANNEL_ID=

# ── MySQL del hosting de la web ────────────────────────────
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASS=
DB_NAME=scrapbook_melon
# Pon DB_SSL=true si tu hosting exige TLS (Planetscale, RDS, etc.)
DB_SSL=
