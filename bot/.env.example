# Renombra este archivo a .env y rellena los valores reales.
# En Discloud: lee el .env del ZIP automáticamente al deployar.
# En Hostinger Node.js apps: NO uses este fichero. Pega cada variable en
# hPanel → Avanzado → Node.js → Environment Variables. Passenger las
# inyecta en process.env y `dotenv/config` las respeta tal cual.

# ── Discord ────────────────────────────────────────────────
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=

# ── Configuración de puntos ────────────────────────────────
POINTS_PER_MESSAGE=1
# Puntos otorgados por cada "intervalo" completo en voz.
POINTS_PER_VOICE_MINUTE=1
# Cuántos minutos completos = 1 intervalo. Con 2 → 1 punto cada 2 min.
VOICE_MINUTES_PER_POINT=2
POINTS_PER_REACTION=10
# Cooldown anti-spam por usuario entre mensajes.
MESSAGE_COOLDOWN_SECONDS=2
# IDs de canales separados por coma; ej: 1234567890,9876543210
EXCLUDED_CHANNEL_IDS=

# ── Canal de artes (#artes) — solo aquí se cuentan reacciones de corazón
# sobre mensajes publicados con el webhook de Melon Hub. Mismo valor que
# MELON_HUB_CHANNEL_ID en el .env del sitio.
MELON_HUB_CHANNEL_ID=

# ── MySQL del hosting ──────────────────────────────────────
# En Hostinger: hPanel → Bases de datos → MySQL Remoto, autoriza la IP
# del Node.js app (o usa "%" como host permitido). DB_HOST suele ser
# `localhost` si la BD vive en el mismo plan, o el hostname remoto que
# Hostinger te dé (algo como `srv-XXX.hstgr.io`).
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASS=
# Convención Hostinger: u<userId>_<nombreLibre>
DB_NAME=u546786567_melonhub
# Pon DB_SSL=true si tu hosting exige TLS (Planetscale, RDS, etc.)
DB_SSL=

# ── Hostinger Node.js (Passenger) ──────────────────────────
# PORT lo asigna Passenger automáticamente y bot.js lo lee. NO hace falta
# rellenarlo aquí ni en hPanel. Lo dejamos documentado por si en local
# quieres cambiarlo.
# PORT=3000
