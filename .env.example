# ──────────────────────────────────────────────────────────────────────
#  Configuración por entorno — COPIA esto a `.env` y rellena los valores.
#  .env está en .gitignore: nunca lo subas al repo ni al hosting público
#  (la propia .htaccess también bloquea su acceso vía HTTP por si acaso).
# ──────────────────────────────────────────────────────────────────────

# ─── Base de datos ────────────────────────────────────────────────────
# En XAMPP local: localhost / scrapbook_melon / root / (vacío)
# En hosting compartido (InfinityFree, 000webhost, OVH, etc.) tu panel
# te da el nombre del host de MySQL (suele ser distinto de localhost),
# y un nombre de BD prefijado tipo `epiz_XXX_scrapbook`.
DB_HOST=localhost
DB_NAME=scrapbook_melon
DB_USER=root
DB_PASS=

# ─── Spotify (https://developer.spotify.com/dashboard) ────────────────
# Añade el dominio de tu hosting a "Redirect URIs":
#   https://TU-DOMINIO/scrapbookOnline/   (o donde subas el app)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ─── Google OAuth — Drive API (apps/dnd.php) ──────────────────────────
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0
# "Authorized JavaScript origins": añade https://TU-DOMINIO
GOOGLE_CLIENT_ID=

# ─── Tidal (https://developer.tidal.com) ──────────────────────────────
# Crea una app y usa el flujo "client credentials". Permite leer el
# catálogo y playlists públicas para importarlas (se resuelven a YouTube).
TIDAL_CLIENT_ID=
TIDAL_CLIENT_SECRET=
# País del catálogo (ISO 3166-1 alpha-2): US, ES, GB, ...
TIDAL_COUNTRY=US

# ──────────────────────────────────────────────────────────────────────
#  Notas para hosting externo:
#  - Importa migrations/001_full_schema.sql vía phpMyAdmin antes de usar.
#  - Carpetas que necesitan escritura (chmod 0775 / 0664):
#      assets/themes/  (CSS generados)
#      assets/img/  assets/img/wallpapers/  assets/img/start-icons/  (subidas)
#      assets/music/  (cache de token Spotify)
#      uploads/momentos/  (fotos de calendario)
#  - SSE (notifications-stream.php / item-notifications-stream.php) hace
#    polling de 25 s. Algunos hosts gratuitos (InfinityFree free tier)
#    cortan conexiones largas: las notificaciones tardarán más pero el
#    resto del sitio sigue funcionando.
# ──────────────────────────────────────────────────────────────────────
