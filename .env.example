# Copia este fichero a .env y rellena los valores reales.
# .env está en .gitignore — nunca se sube al repo.

# Base de datos
DB_HOST=localhost
DB_NAME=scrapbook_melon
DB_USER=root
DB_PASS=

# Spotify (https://developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Google OAuth (https://console.cloud.google.com → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=
